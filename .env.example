# Copy this file to .env and fill in your API keys.
# .env is gitignored and never enters the container image.
#
# Only keys listed here are passed to the container.
# Never pass host environment variables blindly.

# --- LLM Authentication ---
#
# Primary method: Claude Code OAuth credentials are mounted read-only
# from ~/.claude/.credentials.json (configured in docker-compose.yml).
# This uses your existing Claude subscription (Pro, Max, Teams, Enterprise).
# No configuration needed here — it works automatically.
#
# Alternative: if you prefer API key auth (pay-per-use, separate billing),
# uncomment and fill in:
# ANTHROPIC_API_KEY=

# Optional: additional LLM providers
# OPENAI_API_KEY=
# MINIMAX_API_KEY=
