# Inner Alcatraz repo - agent workspace with its own .git
# This directory is mounted into Docker containers and managed by agents.
# Its contents are promoted to the outer repo via the promotion script.
alcatraz/

# Environment variables with secrets - never commit
.env

# Machine-specific Alcatraz UID (legacy, now stored in .env)
.sandbox_env

# Test artifacts (temporary repos created during promotion tests)
test/**/promotion_temp_output/